// SQLite configuration
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String    @id @default(cuid())
  username            String    @unique
  email               String    @unique
  password            String
  role                String    @default("USER") // "ADMIN" or "USER"
  isApproved          Boolean   @default(false)  // Requires Admin approval to log in
  autoApproveRequests Boolean   @default(false)  // If true, requests skip the admin queue
  canDownload         Boolean   @default(false)
  avatar              String?
  banner                String?
  createdAt           DateTime  @default(now())
  
  
  // This tells Prisma that a User can have an array of Requests
  requests            Request[]

  // NEW: Link to reading progress
  readProgresses      ReadProgress[]

  favorites           Favorite[]

  // ADD THIS LINE:
  collections         Collection[]

  trophies            UserTrophy[]

  issueReports        IssueReport[] 
}

model Request {
  id                 String   @id @default(cuid())
  userId             String   // The Foreign Key storing the User's ID
  volumeId           String
  status             String   // PENDING_APPROVAL, PENDING, DOWNLOADING, MANUAL_DDL, IMPORTED
  progress           Int      @default(0)
  retryCount         Int      @default(0)
  downloadLink       String?
  activeDownloadName String?
  imageUrl           String?
  notified            Boolean  @default(false)  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // This links the userId field above to the actual User model
  user               User     @relation(fields: [userId], references: [id])
}

model Series {
  id          String   @id @default(cuid())
  cvId        Int      @unique
  name        String
  year        Int
  publisher   String?
  folderPath  String
  monitored   Boolean?
  issues      Issue[]
  isManga     Boolean  @default(false)
  favorites           Favorite[]
  // ADD THIS LINE:
  collectionItems CollectionItem[]
  issueReports    IssueReport[]
  size        Float?   @default(0)
}

model Issue {
  id          String   @id @default(cuid())
  seriesId    String
  series      Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  cvId        Int      @unique
  number      String   
  status      String   @default("WANTED") // Changed from Enum to String
  filePath    String?
  downloadId  String?

  // NEW: Link to reading progress
  readProgresses ReadProgress[]

  @@unique([seriesId, number])  
}

model IssueReport {
  id            String   @id @default(cuid())
  seriesId      String
  userId        String
  description   String   // What is wrong with the series
  status        String   @default("OPEN") // "OPEN" or "CLOSED"
  adminComment  String?  // The response from the admin when closed
  notified      Boolean  @default(false) // For the header notification bell
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  series        Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MetadataCache {
  key       String   @id
  data      String   
  expiresAt DateTime
}

model SystemConfig {
  key   String @id
  value String // JSON string for arrays/objects
}

model SystemSetting {
  key   String @id @unique
  value String
}

model ReadProgress {
  id          String   @id @default(cuid())
  userId      String
  issueId     String
  currentPage Int      @default(0)
  totalPages  Int      @default(0)
  isCompleted Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue       Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  // This ensures a user can only have one progress record per issue
  @@unique([userId, issueId]) 
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  seriesId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  // Ensures a user can only favorite a specific series once
  @@unique([userId, seriesId])
}

model Collection {
  id          String           @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userId      String           
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionItem[]
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  seriesId     String
  order        Int        @default(0) // Used to sort the reading order
  
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  series       Series     @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  // Ensure a series can only be added to a specific collection once
  @@unique([collectionId, seriesId]) 
}

model JobLog {
  id          String   @id @default(cuid())
  jobType     String   // e.g., 'METADATA_SYNC', 'LIBRARY_SCAN', 'SERIES_MONITOR'
  status      String   // e.g., 'COMPLETED', 'FAILED', 'COMPLETED_WITH_ERRORS'
  relatedItem String?  // Optional: The specific series name if the log is about a specific item
  durationMs  Int?     // How long the job took in milliseconds
  attempts    Int      @default(1)
  message     String?  // Detailed log output
  createdAt   DateTime @default(now())
}

model Trophy {
  id             String       @id @default(cuid())
  name           String       // e.g., "Avid Reader"
  description    String       // e.g., "Read 100 Comics"
  iconUrl        String?      // Path to the uploaded trophy image
  actionType     String       // e.g., "READ_COUNT", "REQUEST_COUNT", "PUBLISHER_COUNT"
  targetValue    Int          // e.g., 100
  createdAt      DateTime     @default(now())

  earnedBy       UserTrophy[]
}

model UserTrophy {
  id          String   @id @default(cuid())
  userId      String
  trophyId    String
  notified    Boolean  @default(false) // For the header notification bell
  earnedAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trophy      Trophy   @relation(fields: [trophyId], references: [id], onDelete: Cascade)

  // A user can only earn a specific trophy once
  @@unique([userId, trophyId])
}