// SQLite configuration
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String    @id @default(cuid())
  username            String    @unique
  email               String    @unique
  password            String
  role                String    @default("USER") // "ADMIN" or "USER"
  isApproved          Boolean   @default(false)  // Requires Admin approval to log in
  autoApproveRequests Boolean   @default(false)  // If true, requests skip the admin queue
  canDownload         Boolean   @default(false)
  avatar              String?
  banner              String?
  createdAt           DateTime  @default(now())
  
  requests            Request[]
  readProgresses      ReadProgress[]
  favorites           Favorite[]
  collections         Collection[]
  readingLists        ReadingList[]
  trophies            UserTrophy[]
  issueReports        IssueReport[]

  bookmarks           Bookmark[]
  reviews             Review[]

  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  sessionVersion   Int     @default(0)

  dailyReadingStats DailyReadingStat[]

  apiKeys             ApiKey[]  @relation("ApiKeysActsAs")
  createdApiKeys      ApiKey[]  @relation("ApiKeysCreatedBy")
  opdsKeys        OpdsKey[]

  koreaderSyncs KoreaderSync[]
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  prefix      String
  
  userId      String
  user        User      @relation("ApiKeysActsAs", fields: [userId], references: [id], onDelete: Cascade)
  
  createdById String
  createdBy   User      @relation("ApiKeysCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([createdById])
}

model Request {
  id                 String   @id @default(cuid())
  userId             String   
  volumeId           String
  status             String   // PENDING_APPROVAL, PENDING, DOWNLOADING, MANUAL_DDL, IMPORTED
  progress           Int      @default(0)
  retryCount         Int      @default(0)
  downloadLink       String?
  activeDownloadName String?
  imageUrl           String?
  notified           Boolean  @default(false)  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([volumeId])
}

// --- NEW MULTI-LIBRARY ARCHITECTURE ---
model Library {
  id        String   @id @default(cuid())
  name      String
  path      String   @unique
  isManga   Boolean  @default(false)
  isDefault Boolean  @default(false)

  series    Series[]
}

model Series {
  id              String   @id @default(cuid())
  cvId            Int?
  metadataId      String?  // Can hold "4050-12345" or a MangaDex UUID
  metadataSource  String   @default("COMICVINE") // COMICVINE, MANGADEX, ANILIST, NONE
  name            String
  year            Int
  publisher       String?
  folderPath      String
  monitored       Boolean?
  isManga         Boolean  @default(false)
  size            Float?   @default(0)
  
  description     String?
  status          String?
  coverUrl        String?
  issues          Issue[]
  favorites       Favorite[]
  collectionItems CollectionItem[]
  issueReports    IssueReport[]

  reviews         Review[]

  // Links to the new Library model
  libraryId       String?
  library         Library? @relation(fields: [libraryId], references: [id], onDelete: SetNull)

  @@index([libraryId])

  @@unique([metadataSource, metadataId]) // Ensure we don't duplicate imports from the same source
}

model Issue {
  id              String   @id @default(cuid())
  seriesId        String
  series          Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  cvId            Int?
  metadataId      String?  
  metadataSource  String   @default("COMICVINE")
  number          String   
  status          String   @default("WANTED") 
  filePath        String?
  downloadId      String?
  pageCount       Int      @default(0)

  name            String?
  description     String?
  releaseDate     String?
  coverUrl        String?
  writers         String?  // Stored as JSON string
  artists         String?  // Stored as JSON string
  characters      String?  // Stored as JSON string
  genres          String?  // Stored as JSON string
  storyArcs       String?  // Stored as JSON string

  readProgresses  ReadProgress[]
  readingListItems ReadingListItem[]

  bookmarks       Bookmark[]

  @@index([seriesId])
  @@index([metadataId])
  @@index([metadataSource])
}

model IssueReport {
  id            String   @id @default(cuid())
  seriesId      String
  userId        String
  description   String   
  status        String   @default("OPEN") 
  adminComment  String?
  notified      Boolean  @default(false) 
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  series        Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([seriesId])
  @@index([userId])
  @@index([status])
}

// --- NEW CONFIGURATION TABLES ---

model DownloadClient {
  id         String  @id @default(cuid())
  name       String
  type       String  // qbit, sab, deluge, nzbget
  protocol   String  // Torrent, Usenet
  url        String
  user       String?
  pass       String?
  apiKey     String?
  category   String?
  remotePath String?
  localPath  String?
}

model DiscordWebhook {
  id       String  @id @default(cuid())
  name     String
  url      String
  isActive Boolean @default(true)
  events   String  // JSON array string of event triggers
  botUsername  String?
  botAvatarUrl String?
}

model Indexer {
  id        Int     @id // Prowlarr's internal ID
  name      String
  protocol  String
  priority  Int     @default(25)
  seedTime  Int     @default(0)
  seedRatio Float   @default(0)
  rss       Boolean @default(true)
}

model CustomHeader {
  id    String @id @default(cuid())
  key   String
  value String
}

model SearchAcronym {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// --------------------------------

model SystemSetting {
  key   String @id @unique
  value String
}

model ReadProgress {
  id          String   @id @default(cuid())
  userId      String
  issueId     String
  currentPage Int      @default(0)
  totalPages  Int      @default(0)
  isCompleted Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue       Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId]) 
  @@index([userId])
  @@index([issueId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  seriesId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
  @@index([userId])
  @@index([seriesId])
}

model Collection {
  id          String           @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userId      String           
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionItem[]

  @@index([userId])
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  seriesId     String
  order        Int      @default(0) 
  
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  series       Series     @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([collectionId, seriesId]) 
  @@index([collectionId])
  @@index([seriesId])
}

model JobLog {
  id          String   @id @default(cuid())
  jobType     String   
  status      String   
  relatedItem String?
  durationMs  Int?
  attempts    Int      @default(1)
  message     String?
  createdAt   DateTime @default(now())

  @@index([jobType])
  @@index([status])
}

model Trophy {
  id             String       @id @default(cuid())
  name           String       
  description    String       
  iconUrl        String?
  actionType     String       
  targetValue    Int          
  createdAt      DateTime     @default(now())

  earnedBy       UserTrophy[]
}

model UserTrophy {
  id          String   @id @default(cuid())
  userId      String
  trophyId    String
  notified    Boolean  @default(false) 
  earnedAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trophy      Trophy   @relation(fields: [trophyId], references: [id], onDelete: Cascade)

  @@unique([userId, trophyId])
  @@index([userId])
  @@index([trophyId])
}

model ReadingList {
  id          String            @id @default(cuid())
  name        String
  description String?
  coverUrl    String?
  userId      String?
  user        User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ReadingListItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  shareId     String?           @unique

  @@index([userId])
}

model ReadingListItem {
  id          String       @id @default(cuid())
  listId      String
  list        ReadingList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  
  issueId     String?      
  issue       Issue?       @relation(fields: [issueId], references: [id], onDelete: SetNull)
  
  cvIssueId   Int?
  title       String       
  order       Int          

  @@index([listId])
  @@index([issueId])
}

model OpdsKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  prefix     String
  
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}

model KoreaderSync {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document    String   // KOReader's document hash or filename
  progress    String   // KOReader's proprietary location string
  percentage  Float
  device      String
  deviceId    String
  timestamp   Int      // Unix timestamp

  @@unique([userId, document])
  @@index([userId])
}

// --- DISTRIBUTED ATOMIC LOCKS ---
model JobLock {
  id        String   @id
  lockedAt  DateTime @default(now())
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  issueId   String
  pageIndex Int
  note      String?  // Optional user notes/highlights
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId, pageIndex]) // Prevent duplicate bookmarks on the same page
  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  seriesId  String
  rating    Int      @default(0) // 1-5 stars
  text      String?  // Optional text review
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId]) // One review per series per user
  @@index([seriesId])
}

model DailyReadingStat {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime // Stored as the start of the day (00:00:00)
  pagesRead Int      @default(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}