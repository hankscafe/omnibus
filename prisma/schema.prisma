// src/prisma/schema.prisma

// SQLite configuration
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String    @id @default(cuid())
  username            String    @unique
  email               String    @unique
  password            String
  role                String    @default("USER") // "ADMIN" or "USER"
  isApproved          Boolean   @default(false)
  autoApproveRequests Boolean   @default(false)
  canDownload         Boolean   @default(false)
  avatar              String?
  banner              String?
  createdAt           DateTime  @default(now())
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?
  
  // SECURITY FIX: Used to invalidate all active sessions instantly
  sessionVersion      Int       @default(0)

  requests            Request[]
  readProgresses      ReadProgress[]
  favorites           Favorite[]
  collections         Collection[]
  readingLists        ReadingList[]
  trophies            UserTrophy[]
  issueReports        IssueReport[]
  bookmarks           Bookmark[]
  reviews             Review[]
  dailyReadingStats   DailyReadingStat[]
  auditLogs           AuditLog[]
  apiKeys             ApiKey[]  @relation("ApiKeysActsAs")
  createdApiKeys      ApiKey[]  @relation("ApiKeysCreatedBy")
  opdsKeys            OpdsKey[]
  koreaderSyncs       KoreaderSync[]
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  prefix      String
  
  userId      String
  user        User      @relation("ApiKeysActsAs", fields: [userId], references: [id], onDelete: Cascade)
  
  createdById String
  createdBy   User      @relation("ApiKeysCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([createdById])
}

model Request {
  id                 String   @id @default(cuid())
  userId             String   
  volumeId           String
  status             String   // PENDING_APPROVAL, PENDING, DOWNLOADING, MANUAL_DDL, IMPORTED
  progress           Int      @default(0)
  retryCount         Int      @default(0)
  downloadLink       String?
  activeDownloadName String?
  imageUrl           String?
  notified           Boolean  @default(false)  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([volumeId])
}

model Library {
  id        String   @id @default(cuid())
  name      String
  path      String   @unique
  isManga   Boolean  @default(false)
  isDefault Boolean  @default(false)

  series    Series[]
}

model Series {
  id              String   @id @default(cuid())
  cvId            Int?
  metadataId      String?  
  metadataSource  String   @default("COMICVINE") 
  matchState      String?  @default("UNMATCHED")
  name            String
  year            Int
  publisher       String?
  folderPath      String
  monitored       Boolean?
  isManga         Boolean  @default(false)
  size            Float?   @default(0)
  
  description     String?
  status          String?
  coverUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  issues          Issue[]
  favorites       Favorite[]
  collectionItems CollectionItem[]
  issueReports    IssueReport[]
  reviews         Review[]

  libraryId       String?
  library         Library? @relation(fields: [libraryId], references: [id], onDelete: SetNull)

  @@index([libraryId])
  @@unique([metadataSource, metadataId]) 
}

model Issue {
  id              String   @id @default(cuid())
  seriesId        String
  series          Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  cvId            Int?
  metadataId      String?  
  metadataSource  String   @default("COMICVINE")
  matchState      String?  @default("UNMATCHED")
  number          String   
  status          String   @default("WANTED") 
  filePath        String?
  downloadId      String?
  pageCount       Int      @default(0)

  name            String?
  description     String?
  releaseDate     String?
  coverUrl        String?
  writers         String?
  artists         String?
  coverArtists    String?  // <-- NEW
  colorists       String?  // <-- NEW
  letterers       String?  // <-- NEW
  characters      String?
  genres          String?
  storyArcs       String?
  teams           String?  // <-- NEW
  locations       String?  // <-- NEW

  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  readProgresses  ReadProgress[]
  readingListItems ReadingListItem[]
  bookmarks       Bookmark[]

  @@index([seriesId])
  @@index([metadataId])
  @@index([metadataSource])
}

model IssueReport {
  id            String   @id @default(cuid())
  seriesId      String
  userId        String
  description   String   
  status        String   @default("OPEN") 
  adminComment  String?
  notified      Boolean  @default(false) 
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  series        Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([seriesId])
  @@index([userId])
  @@index([status])
}

model DownloadClient {
  id         String  @id @default(cuid())
  name       String
  type       String  
  protocol   String  
  url        String
  user       String?
  pass       String?
  apiKey     String?
  category   String?
  remotePath String?
  localPath  String?
}

model DiscordWebhook {
  id       String  @id @default(cuid())
  name     String
  url      String
  isActive Boolean @default(true)
  events   String  
  botUsername  String?
  botAvatarUrl String?
}

model Indexer {
  id        Int     @id 
  name      String
  protocol  String
  priority  Int     @default(25)
  seedTime  Int     @default(0)
  seedRatio Float   @default(0)
  rss       Boolean @default(true)
}

model CustomHeader {
  id    String @id @default(cuid())
  key   String
  value String
}

model SearchAcronym {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SystemSetting {
  key   String @id @unique
  value String
}

model ReadProgress {
  id          String   @id @default(cuid())
  userId      String
  issueId     String
  currentPage Int      @default(0)
  totalPages  Int      @default(0)
  isCompleted Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue       Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId]) 
  @@index([userId])
  @@index([issueId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  seriesId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
  @@index([userId])
  @@index([seriesId])
}

model Collection {
  id          String           @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userId      String           
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionItem[]

  @@index([userId])
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  seriesId     String
  order        Int      @default(0) 
  
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  series       Series     @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([collectionId, seriesId]) 
  @@index([collectionId])
  @@index([seriesId])
}

model JobLog {
  id          String   @id @default(cuid())
  jobType     String   
  status      String   
  relatedItem String?
  durationMs  Int?
  attempts    Int      @default(1)
  message     String?
  createdAt   DateTime @default(now())

  @@index([jobType])
  @@index([status])
}

model Trophy {
  id             String       @id @default(cuid())
  name           String       
  description    String       
  iconUrl        String?
  actionType     String       
  targetValue    Int          
  createdAt      DateTime     @default(now())

  earnedBy       UserTrophy[]
}

model UserTrophy {
  id          String   @id @default(cuid())
  userId      String
  trophyId    String
  notified    Boolean  @default(false) 
  earnedAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trophy      Trophy   @relation(fields: [trophyId], references: [id], onDelete: Cascade)

  @@unique([userId, trophyId])
  @@index([userId])
  @@index([trophyId])
}

model ReadingList {
  id          String            @id @default(cuid())
  name        String
  description String?
  coverUrl    String?
  userId      String?
  user        User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ReadingListItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  shareId     String?           @unique

  @@index([userId])
}

model ReadingListItem {
  id          String       @id @default(cuid())
  listId      String
  list        ReadingList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  
  issueId     String?
  issue       Issue?       @relation(fields: [issueId], references: [id], onDelete: Cascade)
  
  cvIssueId   Int?
  title       String       
  order       Int          

  @@index([listId])
  @@index([issueId])
}

model OpdsKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  prefix     String
  
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  @@index([userId])
}

model KoreaderSync {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document    String   
  progress    String   
  percentage  Float
  device      String
  deviceId    String
  timestamp   Int    

  @@unique([userId, document])
  @@index([userId])
}

model JobLock {
  id        String   @id
  lockedAt  DateTime @default(now())
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  issueId   String
  pageIndex Int
  note      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId, pageIndex]) 
  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  seriesId  String
  rating    Int      @default(0) 
  text      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId]) 
  @@index([seriesId])
}

model DailyReadingStat {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime 
  pagesRead Int      @default(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action      String   
  details     String?
  ipAddress   String?
  
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
}

model HosterAccount {
  id        String   @id @default(cuid())
  name      String
  hoster    String   // e.g., 'mega', 'mediafire', 'pixeldrain'
  username  String?
  password  String?
  apiKey    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DigestHistory {
  id        String   @id @default(uuid())
  seriesId  String
  issueNum  String
  sentAt    DateTime @default(now())

  @@unique([seriesId, issueNum])
}