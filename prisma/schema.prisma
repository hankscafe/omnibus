// SQLite configuration
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String    @id @default(cuid())
  username            String    @unique
  email               String    @unique
  password            String
  role                String    @default("USER") // "ADMIN" or "USER"
  isApproved          Boolean   @default(false)  // Requires Admin approval to log in
  autoApproveRequests Boolean   @default(false)  // If true, requests skip the admin queue
  canDownload         Boolean   @default(false)
  avatar              String?
  banner              String?
  createdAt           DateTime  @default(now())
  
  requests            Request[]
  readProgresses      ReadProgress[]
  favorites           Favorite[]
  collections         Collection[]
  readingLists        ReadingList[]
  trophies            UserTrophy[]
  issueReports        IssueReport[] 
}

model Request {
  id                 String   @id @default(cuid())
  userId             String   
  volumeId           String
  status             String   // PENDING_APPROVAL, PENDING, DOWNLOADING, MANUAL_DDL, IMPORTED
  progress           Int      @default(0)
  retryCount         Int      @default(0)
  downloadLink       String?
  activeDownloadName String?
  imageUrl           String?
  notified           Boolean  @default(false)  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id])
}

model Series {
  id              String   @id @default(cuid())
  cvId            Int      @unique
  name            String
  year            Int
  publisher       String?
  folderPath      String
  monitored       Boolean?
  isManga         Boolean  @default(false)
  size            Float?   @default(0)
  
  // --- NEW METADATA FIELDS ---
  description     String?
  status          String?  // e.g., "Ongoing" or "Ended"
  coverUrl        String?

  issues          Issue[]
  favorites       Favorite[]
  collectionItems CollectionItem[]
  issueReports    IssueReport[]
}

model Issue {
  id              String   @id @default(cuid())
  seriesId        String
  series          Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  cvId            Int      @unique
  number          String   
  status          String   @default("WANTED") 
  filePath        String?
  downloadId      String?

  // --- NEW METADATA FIELDS ---
  name            String?
  description     String?
  releaseDate     String?
  coverUrl        String?
  writers         String?  // Stored as JSON string
  artists         String?  // Stored as JSON string
  characters      String?  // Stored as JSON string

  readProgresses  ReadProgress[]
  readingListItems ReadingListItem[]

  @@unique([seriesId, number])  
}

model IssueReport {
  id            String   @id @default(cuid())
  seriesId      String
  userId        String
  description   String   
  status        String   @default("OPEN") 
  adminComment  String?
  notified      Boolean  @default(false) 
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  series        Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MetadataCache {
  key       String   @id
  data      String   
  expiresAt DateTime
}

model SystemConfig {
  key   String @id
  value String 
}

model SystemSetting {
  key   String @id @unique
  value String
}

model ReadProgress {
  id          String   @id @default(cuid())
  userId      String
  issueId     String
  currentPage Int      @default(0)
  totalPages  Int      @default(0)
  isCompleted Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue       Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId]) 
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  seriesId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
}

model Collection {
  id          String           @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userId      String           
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionItem[]
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  seriesId     String
  order        Int        @default(0) 
  
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  series       Series     @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([collectionId, seriesId]) 
}

model JobLog {
  id          String   @id @default(cuid())
  jobType     String   
  status      String   
  relatedItem String?
  durationMs  Int?
  attempts    Int      @default(1)
  message     String?
  createdAt   DateTime @default(now())
}

model Trophy {
  id             String       @id @default(cuid())
  name           String       
  description    String       
  iconUrl        String?
  actionType     String       
  targetValue    Int          
  createdAt      DateTime     @default(now())

  earnedBy       UserTrophy[]
}

model UserTrophy {
  id          String   @id @default(cuid())
  userId      String
  trophyId    String
  notified    Boolean  @default(false) 
  earnedAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trophy      Trophy   @relation(fields: [trophyId], references: [id], onDelete: Cascade)

  @@unique([userId, trophyId])
}

model ReadingList {
  id          String            @id @default(cuid())
  name        String
  description String?
  coverUrl    String?
  userId      String?           // Nullable if it's a global/shared event, or linked to a User
  user        User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ReadingListItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model ReadingListItem {
  id          String       @id @default(cuid())
  listId      String
  list        ReadingList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  
  issueId     String?      // Links to your physical Issue in the DB (if downloaded)
  issue       Issue?       @relation(fields: [issueId], references: [id], onDelete: SetNull)
  
  cvIssueId   Int?         // The ComicVine ID (used to track and request MISSING issues)
  title       String       // e.g., "Civil War #1"
  order       Int          // The reading order position (1, 2, 3...)
  
  @@unique([listId, order])
}